@model ImcViewModel

@{
    ViewData["Title"] = "Calculadora IMC";
}

<h2>Calculadora IMC</h2>

<form asp-action="Index" method="post">

    <div class="mb-3">
        <label asp-for="Peso"></label>
        <input asp-for="Peso" class="form-control" />
        <span asp-validation-for="Peso" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Altura"></label>
        <input asp-for="Altura" class="form-control" />
        <span asp-validation-for="Altura" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">
        Calcular
    </button>

</form>

@if (Model != null && Model.Resultado > 0)
{
    <div class="alert alert-success mt-3">
        <h3>Resultado</h3>

        <p>
            <strong>IMC:</strong>
            @Model.Resultado.ToString("F2")
        </p>

        <p>
            <strong>Classificação:</strong>
            @Model.Classificacao
        </p>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}