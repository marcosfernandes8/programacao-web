@model Aluno

@{
    ViewData["Title"] = "Confirmação";
}

<div class="alert alert-success">
    <h2>Cadastro realizado com sucesso!</h2>
</div>

<div class="card p-3">
    <p><strong>Nome:</strong> @Model.Nome</p>
    <p><strong>Email:</strong> @Model.Email</p>
    <p><strong>RA:</strong> @Model.RA</p>
    <p><strong>Curso:</strong> @Model.Curso</p>
    <p><strong>Data de Nascimento:</strong> @Model.DataNascimento.ToString("dd/MM/yyyy")</p>
</div>

<a asp-action="Cadastrar" class="btn btn-primary mt-3">
    Cadastrar outro
</a>